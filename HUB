<script>
const quotes = [{"greeting": "Bom dia! Que hoje seja produtivo.", "quote": "O sucesso é a soma de pequenos esforços repetidos dia após dia.", "author": "Robert Collier"}, {"greeting": "Bem-vindo! Você está no caminho certo.", "quote": "A única maneira de fazer um ótimo trabalho é amar o que você faz.", "author": "Steve Jobs"}, {"greeting": "Mais um dia incrível começa agora.", "quote": "Não é sobre ter tempo, é sobre criar tempo.", "author": "Oprah Winfrey"}, {"greeting": "Que a sua energia hoje mova montanhas.", "quote": "O segredo para seguir em frente é começar.", "author": "Mark Twain"}, {"greeting": "Hoje é uma nova oportunidade de brilhar.", "quote": "Sonhos não funcionam a menos que você trabalhe.", "author": "John C. Maxwell"}, {"greeting": "Olá! Vamos conquistar mais um dia juntos.", "quote": "A persistência é o caminho do êxito.", "author": "Charles Chaplin"}, {"greeting": "Energia positiva para mais um dia de vitórias.", "quote": "Tudo parece impossível até que seja feito.", "author": "Nelson Mandela"}];
function updateDateTime() {
  const now = new Date();
  const d = now.toLocaleDateString('pt-BR', {weekday:'long',day:'numeric',month:'long'});
  document.getElementById('date-display').textContent = d.charAt(0).toUpperCase() + d.slice(1);
  document.getElementById('time-live').textContent = now.toLocaleTimeString('pt-BR', {hour:'2-digit',minute:'2-digit'});
}
function setGreeting() {
  const idx = new Date().getDay() % quotes.length;
  const q = quotes[idx];
  document.getElementById('greeting-text').textContent = q.greeting;
  document.getElementById('quote-text').innerHTML = '"' + q.quote + '" &mdash; <span class="quote-author">' + q.author + '</span>';
}
updateDateTime();
setGreeting();
setInterval(updateDateTime, 30000);
</script>
</body>
</html>
