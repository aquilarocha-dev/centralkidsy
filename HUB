  <link href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;700&family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --bg:#F8F9FA;
      --surface:#FFFFFF;
      --border:#E8EAED;
      --text:#202124;
      --muted:#5F6368;
      --hint:#9AA0A6;
      --blue:#1A73E8;
    }
    html,body{height:100%;overflow:hidden}
    body{font-family:'Roboto',sans-serif;background:var(--bg);color:var(--text);display:flex;flex-direction:column}

    /* HEADER */
    header{background:var(--surface);border-bottom:1px solid var(--border);padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:52px;flex-shrink:0}
    .logo-wrap{display:flex;align-items:center;gap:10px}
    .logo-img{height:28px;width:auto;border-radius:4px}
    .logo-text{font-family:'Google Sans',sans-serif;font-size:14px;font-weight:500;color:var(--text)}
    .logo-text span{color:var(--muted);font-weight:400}
    .header-right{display:flex;align-items:center;gap:10px}
    .date-chip{background:var(--bg);border:1px solid var(--border);border-radius:99px;padding:4px 13px;font-size:11px;color:var(--muted)}
    #time-live{font-size:12px;color:var(--muted);min-width:38px;text-align:right;font-family:'Google Sans',sans-serif}

    /* SIDE COLUMNS */
    .side-col{position:fixed;display:flex;flex-direction:column;align-items:center;gap:16px;z-index:200;top:50%;transform:translateY(-50%)}
    .side-col-left{left:14px}
    .side-col-right{right:14px}
    .side-btn{display:flex;flex-direction:column;align-items:center;gap:4px;cursor:pointer;text-decoration:none}
    .side-circle{width:52px;height:52px;border-radius:50%;display:flex;align-items:center;justify-content:center;box-shadow:0 1px 8px rgba(32,33,36,.2);background:var(--surface);transition:box-shadow .15s,transform .15s}
    .side-btn:hover .side-circle{box-shadow:0 4px 16px rgba(32,33,36,.28);transform:scale(1.08)}
    .side-label{font-size:9px;color:var(--muted);text-align:center;line-height:1.2;max-width:56px}

    /* MAIN */
    .main-wrap{flex:1;overflow:hidden;padding:10px 90px 8px;display:flex;flex-direction:column;gap:10px}

    /* GREETING */
    .greeting-wrap{text-align:center;flex-shrink:0}
    .greeting-text{font-family:'Google Sans',sans-serif;font-size:19px;font-weight:500;color:var(--text);margin-bottom:3px}
    .quote-text{font-size:11px;color:var(--muted);font-style:italic}
    .quote-author{color:var(--blue);font-style:normal;font-weight:500}

    /* SECTION LABEL */
    .slabel{font-size:10px;font-weight:500;letter-spacing:.08em;text-transform:uppercase;color:var(--hint);margin-bottom:6px}

    /* CARD */
    .card{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:11px 13px;text-decoration:none;display:flex;flex-direction:column;gap:5px;transition:box-shadow .15s,border-color .15s}
    .card:hover{box-shadow:0 1px 10px rgba(32,33,36,.2);border-color:transparent}

    /* MARKETPLACE CARD — icon fills the square */
    .mcard{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:10px 12px;text-decoration:none;display:flex;flex-direction:column;gap:5px;transition:box-shadow .15s,border-color .15s}
    .mcard:hover{box-shadow:0 1px 10px rgba(32,33,36,.2);border-color:transparent}
    .micon{width:36px;height:36px;border-radius:8px;overflow:hidden;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .micon img{width:36px;height:36px;object-fit:cover;border-radius:8px}
    .micon svg{width:28px;height:28px}
    .mname{font-family:'Google Sans',sans-serif;font-size:12px;font-weight:500;color:var(--text);line-height:1.3}
    .mdesc{font-size:10px;color:var(--muted);line-height:1.4}

    .cicon{width:32px;height:32px;border-radius:7px;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden}
    .cicon img{width:32px;height:32px;object-fit:contain;border-radius:7px}
    .cicon svg{width:24px;height:24px}
    .cname{font-family:'Google Sans',sans-serif;font-size:12px;font-weight:500;color:var(--text);line-height:1.3}
    .cdesc{font-size:10px;color:var(--muted);line-height:1.4}

    /* SMALL CARD */
    .scard{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:8px 11px;text-decoration:none;display:flex;align-items:center;gap:8px;transition:box-shadow .15s,border-color .15s}
    .scard:hover{box-shadow:0 1px 10px rgba(32,33,36,.2);border-color:transparent}
    .sicon{width:24px;height:24px;border-radius:5px;display:flex;align-items:center;justify-content:center;flex-shrink:0;overflow:hidden}
    .sicon img{width:24px;height:24px;object-fit:contain;border-radius:4px}
    .sicon svg{width:18px;height:18px}
    .sname{font-family:'Google Sans',sans-serif;font-size:11px;font-weight:500;color:var(--text)}
    .sdesc{font-size:10px;color:var(--muted)}

    /* VISION */
    .vision{background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:9px 18px;text-align:center;flex-shrink:0}
    .vision-label{font-size:9px;font-weight:500;letter-spacing:.1em;text-transform:uppercase;color:var(--hint);margin-bottom:3px}
    .vision-text{font-family:'Google Sans',sans-serif;font-size:12px;color:var(--muted);line-height:1.5;max-width:680px;margin:0 auto}
    .vision-text strong{color:var(--blue);font-weight:500}

    /* GRIDS */
    .g5{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
    .g3{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .g2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .two-col{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .g3s{display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;max-width:560px}

    @keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
    .greeting-wrap{animation:fadeUp .28s ease both}
    .s1{animation:fadeUp .28s ease .05s both}
    .s2{animation:fadeUp .28s ease .10s both}
    .s3{animation:fadeUp .28s ease .15s both}
    .vision{animation:fadeUp .28s ease .20s both}

    .ic-sheets{background:#E6F4EC}
    .ic-analytics{background:#E8F0FE}
    .ic-finance{background:#E6F4F1}
    .ic-atend{background:#F0EBFF}
    .ic-drive{background:#EBF3FF}
    .ic-miro{background:#FFFBEB}
  </style>
</head>
